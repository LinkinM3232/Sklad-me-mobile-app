<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_session"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardElevation="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:padding="18dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_circular"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:progress="70"
                app:indicatorSize="230dp"
                app:trackThickness="9dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/center_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="4 сек"
                android:textAppearance="?attr/textAppearanceHeadlineLarge"
                app:layout_constraintBottom_toBottomOf="@id/progress_circular"
                app:layout_constraintEnd_toEndOf="@id/progress_circular"
                app:layout_constraintStart_toStartOf="@id/progress_circular"
                app:layout_constraintTop_toTopOf="@id/progress_circular" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Вдох "

                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progress_circular"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/title_pattern"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Паттерн"
        app:layout_constraintTop_toBottomOf="@id/card_session"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="26dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_patterns"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/title_pattern"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_44"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4–4"
            android:checked="true"/>

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4-6" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_64"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6–4" />
    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_inhale"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/chip_group_patterns"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/card_exhale"
        android:layout_marginTop="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp">

            <TextView
                android:id="@+id/title_inhale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Вдох"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_inhale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:value="4"
                android:valueFrom="1"
                android:valueTo="12"
                android:stepSize="1"
                app:layout_constraintTop_toBottomOf="@id/title_inhale"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/value_inhale"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/value_inhale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 сек"
                app:layout_constraintTop_toTopOf="@id/slider_inhale"
                app:layout_constraintBottom_toBottomOf="@id/slider_inhale"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_exhale"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:layout_constraintTop_toTopOf="@id/card_inhale"
        app:layout_constraintStart_toEndOf="@id/card_inhale"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp">

            <TextView
                android:id="@+id/title_exhale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выдох"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_exhale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:value="6"
                android:valueFrom="1"
                android:valueTo="12"
                android:stepSize="1"
                app:layout_constraintTop_toBottomOf="@id/title_exhale"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/value_exhale"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/value_exhale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6 сек"
                app:layout_constraintTop_toTopOf="@id/slider_exhale"
                app:layout_constraintBottom_toBottomOf="@id/slider_exhale"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_start"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="СТАРТ"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/button_reset"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_reset"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="СБРОС"
        app:layout_constraintStart_toEndOf="@id/button_start"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>